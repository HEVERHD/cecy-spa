# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/barberapp?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Twilio (WhatsApp)
# Consigue estas en: https://console.twilio.com → "Account Info"
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_WHATSAPP_FROM="whatsapp:+16624992878"

# Cron Secret (for Vercel cron jobs)
CRON_SECRET="generate-a-random-secret-here"

# Resend (Email confirmations)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="citas@tudominio.com"

# Google Maps (Embed API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
